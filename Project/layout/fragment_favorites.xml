<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F2B">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/favHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Favorites"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/favNoteCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0 favorites"
                android:textColor="#5C608A"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_star_filled"
            app:tint="#FFD700" />
    </RelativeLayout>

    <View
        android:id="@+id/favDivider"
        android:layout_below="@id/favHeader"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1D3A"/>

    <!-- RECYCLER VIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/favDivider"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="14dp" />

    <!-- EMPTY STATE -->
    <TextView
        android:id="@+id/favEmptyView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/favDivider"
        android:gravity="center"
        android:text="⭐ No favorite notes yet\nStar your best snippets to see them here"
        android:textColor="#5C608A"
        android:textSize="14sp"
        android:visibility="gone" />

</RelativeLayout>